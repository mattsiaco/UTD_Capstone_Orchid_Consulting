# Copy this file to .env and fill in your keys before running.

# Required — ATTOM Data Solutions API key
ATTOM_API_KEY=your_attom_api_key_here

# Required — RentCast API key (days on market)
RENTCAST_API_KEY=your_rentcast_api_key_here

# Required — Google Maps Geocoding API key (zoning pipeline)
GEOCODING_API_KEY=your_google_maps_api_key_here

# Optional — U.S. Census Bureau API key (unauthenticated access is rate-limited)
CENSUS_API_KEY=your_census_api_key_here
